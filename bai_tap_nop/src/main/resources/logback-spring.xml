<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Đọc đường dẫn và mức log từ application.properties, đồng thời có giá trị dự phòng. -->
    <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="log"/>
    <springProperty scope="context" name="APP_ROOT_LOG_LEVEL" source="logging.level.root" defaultValue="INFO"/>
    <springProperty scope="context" name="APP_CONTROLLER_LOG_LEVEL"
                    source="logging.level.com.yan.bai_tap_nop.controller" defaultValue="TRACE"/>

    <!-- Hai pattern dùng chung giúp định dạng console và file nhất quán. -->
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{60} - %msg%n"/>
    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger{60}:%line - %msg%n"/>

    <!-- Console hiển thị log vận hành của toàn ứng dụng. -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- File debug chứa toàn bộ sự kiện của controller và tự xoay theo ngày/kích thước. -->
    <appender name="DEBUG_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/debug.log</file>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/archived/debug.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- File lỗi chỉ nhận ERROR trở lên, kể cả lỗi phát sinh từ controller. -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <file>${LOG_PATH}/error.log</file>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/archived/error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- Ghi lỗi bất đồng bộ để giảm thời gian chờ trên luồng xử lý request. -->
    <appender name="ASYNC_ERROR" class="ch.qos.logback.classic.AsyncAppender">
        <includeCallerData>true</includeCallerData>
        <neverBlock>true</neverBlock>
        <appender-ref ref="ERROR_FILE"/>
    </appender>

    <!-- Controller ghi đầy đủ vào debug.log và tiếp tục truyền ERROR về root. -->
    <logger name="com.yan.bai_tap_nop.controller" level="${APP_CONTROLLER_LOG_LEVEL}" additivity="true">
        <appender-ref ref="DEBUG_FILE"/>
    </logger>

    <root level="${APP_ROOT_LOG_LEVEL}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_ERROR"/>
    </root>
</configuration>
